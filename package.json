{
  "name": "deveasy",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first web app wrapping the Claude Code CLI with shared, version-controlled agents and an Azure/git cockpit.",
  "license": "UNLICENSED",
  "scripts": {
    "dev:all": "node scripts/dev.mjs",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "node --import tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:latest",
    "db:rollback": "node --import tsx ./node_modules/knex/bin/cli.js --knexfile knexfile.ts migrate:rollback",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "postinstall": "node scripts/fix-node-pty.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "gray-matter": "^4.0.3",
    "helmet": "^8.0.0",
    "keytar": "^7.9.0",
    "knex": "^3.1.0",
    "node-pty": "^1.1.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.61.1",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
