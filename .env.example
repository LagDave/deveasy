# DevEasy environment — copy to .env and adjust. Validated at startup (Constitution §5.6).

# HTTP server (the app + API)
PORT=1234

# PostgreSQL (Docker maps host 1231 -> container 5432; see docker-compose.yml)
DATABASE_URL=postgres://deveasy:deveasy@localhost:1231/deveasy

# Absolute path to the folder holding project clones. Defaults to ./projects.
# On Windows, keep this on the SAME drive as the repo so the shared CLAUDE.md can be
# hardlinked (cross-drive falls back to a copy that won't live-update). See README.
PROJECTS_ROOT=

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# NOTE: ANTHROPIC_API_KEY must NOT be set here. The Claude CLI uses the cached
# subscription login; setting this var would silently switch to paid API credits.
